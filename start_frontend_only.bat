@echo off\nREM Start only the Web Frontend (without Python backend)\nREM Use this if you already have Python backend running in another terminal\n\necho.\necho ===============================================\necho GeoAI Web Frontend (Development Mode)\necho ===============================================\necho.\n\nREM Check if Node.js is installed\nnode --version >nul 2>&1\nif errorlevel 1 (\n    echo ERROR: Node.js is not installed or not in PATH\n    echo Please install Node.js from https://nodejs.org/\n    pause\n    exit /b 1\n)\n\necho Checking if dependencies are installed...\nif not exist \"node_modules\" (\n    echo.\n    echo Installing npm packages...\n    call npm install\n    echo.\n)\n\necho.\necho Starting Next.js development server...\necho Open your browser and navigate to: http://localhost:3000\necho.\necho Make sure Python backend is running on http://localhost:5000\necho If not, run: python geoai_backend.py (from qlda_geoAI folder)\necho.\necho Press Ctrl+C to stop the server\necho.\n\nREM Kill any existing process on port 3000\nfor /f \"tokens=5\" %%a in ('netstat -aon ^| find \"3000\" ^| find \"LISTENING\"') do (\n    taskkill /F /PID %%a 2>nul\n)\n\nnpm run dev\n\npause