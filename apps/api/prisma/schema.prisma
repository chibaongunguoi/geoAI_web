generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  email        String     @unique
  name         String
  passwordHash String
  status       String     @default("ACTIVE")
  roles        UserRole[]
  sessions     Session[]
  auditLogs    AuditLog[]
  layerConfig  LayerUserConfig?
  assetDisplayConfig AssetDisplayUserConfig?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Role {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  description String?
  users       UserRole[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  group       String
  name        String
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Session {
  id           String    @id @default(cuid())
  userId       String
  refreshToken String    @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
}

model LayerUserConfig {
  userId    String   @id
  state     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BuildingProperty {
  id                   String    @id @default(cuid())
  code                 String    @unique
  overtureId           String?   @unique
  name                 String?
  addressLine          String?
  street               String?
  ward                 String?
  district             String?
  city                 String    @default("Da Nang")
  propertyType         String    @default("building")
  status               String    @default("ACTIVE")
  source               String    @default("manual")
  sourceVersion        String?
  level                Float?
  height               Float?
  floors               Int?
  areaSqm              Float?
  centroidLat          Float?
  centroidLng          Float?
  bbox                 Json?
  geometry             Json?
  attributes           Json?
  searchText           String    @default("")
  searchTextNormalized String    @default("")
  embedding            Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  @@index([city, district, ward])
  @@index([street])
  @@index([status])
  @@index([source, overtureId])
  @@index([deletedAt])
  @@index([searchTextNormalized])
}

model AssetDisplayUserConfig {
  userId    String   @id
  state     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
