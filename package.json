{
  "name": "geoai-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @geoai/web",
    "dev:web": "npm run dev -w @geoai/web",
    "dev:api": "npm run start:dev -w @geoai/api",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "test:api": "npm run test -w @geoai/api",
    "test:web": "npm run test -w @geoai/web",
    "prisma:generate": "npm run prisma:generate -w @geoai/api",
    "prisma:migrate": "npm run prisma:migrate -w @geoai/api",
    "prisma:seed": "npm run prisma:seed -w @geoai/api"
  }
}
